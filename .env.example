# PostgreSQL (Docker Compose usa estos valores por defecto)
POSTGRES_USER=buzon
POSTGRES_PASSWORD=buzon_secret
POSTGRES_DB=buzon_utmach

# Conexión de Prisma a la base de datos
DATABASE_URL="postgresql://buzon:buzon_secret@localhost:5432/buzon_utmach?schema=public"

# Auth.js (NextAuth v5)
# Genera un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-este-secreto-por-uno-seguro"
AUTH_URL="http://localhost:3000"

# Credenciales del administrador del dashboard
# Define tus propios valores; NO uses estos placeholders en producción.
ADMIN_EMAIL="cambia-este-correo@example.com"
ADMIN_PASSWORD="define-una-contrasena-segura"
